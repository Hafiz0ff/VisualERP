# Database Configuration
POSTGRES_DB=visualerp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-long-random-postgres-password

# Backend Configuration
DATABASE_URL=postgresql://postgres:change-this-long-random-postgres-password@db:5432/visualerp?schema=public
JWT_SECRET=change-this-long-random-jwt-secret
APP_URL=http://your-server-ip-or-domain
NODE_ENV=production
FRONTEND_PORT=80

# ERP Localization Defaults
DEFAULT_LOCALE=ru
DEFAULT_CURRENCY=RUB
DEFAULT_TIMEZONE=UTC
